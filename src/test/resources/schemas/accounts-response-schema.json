{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Accounts Response Schema",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "required": [
      "id",
      "customerId",
      "type",
      "balance"
    ],
    "properties": {
      "id": {
        "type": [
          "integer",
          "number"
        ]
      },
      "customerId": {
        "type": [
          "integer",
          "number"
        ]
      },
      "type": {
        "type": "string",
        "minLength": 1
      },
      "balance": {
        "type": [
          "number",
          "integer"
        ]
      }
    },
    "additionalProperties": true
  }
}